APP_ENV=dev
APP_VERSION=dev
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
POSTGRES_DB=personal_ai
POSTGRES_USER=personal_ai
POSTGRES_PASSWORD=personal_ai
POSTGRES_PORT=5432

# Supabase (required)
# Dev defaults target local Supabase stack (CLI/Docker).
# For staging/prod, use managed project URL and environment-specific keys.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me
SUPABASE_JWT_SECRET=replace_me
APP_DEV_JWT_SECRET=dev_jwt_secret
SUPABASE_DB_URL=postgresql://personal_ai:personal_ai@localhost:5432/personal_ai
SUPABASE_STORAGE_BUCKET_RECEIPTS=receipts
SMOKE_TEST_EMAIL=replace_me
SMOKE_TEST_PASSWORD=replace_me

# OpenAI (required)
OPENAI_API_KEY=replace_me
OPENAI_MODEL_TEXT=gpt-4.1-mini
OPENAI_MODEL_TRANSCRIPTION=whisper-1

# Stripe (required for billing phases)
STRIPE_SECRET_KEY=replace_me
STRIPE_WEBHOOK_SECRET=replace_me
STRIPE_PRICE_PREMIUM_MONTHLY=price_replace_me

# API behavior
APP_CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
# Legacy alias kept for compatibility with older local scripts/config.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
REQUEST_TIMEOUT_SECONDS=30
RATE_LIMIT_REQUESTS_PER_MINUTE=120
DATA_EXPORT_URL_TTL_SECONDS=900

# AI cost controls
AI_TOKEN_BUDGET_FREE=200000
AI_TOKEN_BUDGET_PREMIUM=2000000
