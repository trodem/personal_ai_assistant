APP_ENV=dev
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
POSTGRES_DB=personal_ai
POSTGRES_USER=personal_ai
POSTGRES_PASSWORD=personal_ai
POSTGRES_PORT=5432

# Supabase (required)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me
SUPABASE_JWT_SECRET=replace_me
SUPABASE_DB_URL=postgresql://personal_ai:personal_ai@localhost:5432/personal_ai
SUPABASE_STORAGE_BUCKET_RECEIPTS=receipts

# OpenAI (required)
OPENAI_API_KEY=replace_me
OPENAI_MODEL_TEXT=gpt-4.1-mini
OPENAI_MODEL_TRANSCRIPTION=whisper-1

# Stripe (required for billing phases)
STRIPE_SECRET_KEY=replace_me
STRIPE_WEBHOOK_SECRET=replace_me
STRIPE_PRICE_PREMIUM_MONTHLY=price_replace_me

# API behavior
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
REQUEST_TIMEOUT_SECONDS=30
RATE_LIMIT_REQUESTS_PER_MINUTE=120
DATA_EXPORT_URL_TTL_SECONDS=900
