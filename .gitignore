# -----------------------------------------------------------------------------
# Personal AI Assistant - Global .gitignore
# Covers: Python/FastAPI, Flutter/Dart, Docker, IDEs, OS files, logs, secrets
# -----------------------------------------------------------------------------

# ---- OS ----
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---- Editor / IDE ----
.idea/
.vscode/
*.code-workspace
*.suo
*.user
*.userossc
*.sln.docstates
*.swp
*.swo
*~

# ---- Env / secrets ----
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/

# ---- Logs / runtime ----
*.log
logs/
tmp/
temp/
*.tmp
*.pid
*.seed

# ---- Python / FastAPI ----
__pycache__/
*.py[cod]
*.pyd
*.so
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.nox/
.tox/
.hypothesis/
.coverage
.coverage.*
coverage.xml
htmlcov/
dist/
build/
site/
.eggs/
*.egg-info/
pip-wheel-metadata/
.venv/
venv/
env/
ENV/

# ---- Jupyter ----
.ipynb_checkpoints/

# ---- Node (if tooling/scripts are added) ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Flutter / Dart ----
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
**/build/
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
android/.gradle/
android/app/debug/
android/app/profile/
android/app/release/

# ---- Android / Java / Kotlin ----
*.iml
.gradle/
local.properties
captures/

# ---- Xcode / iOS ----
DerivedData/
*.xcworkspace/
*.xcuserdata/
*.xcuserstate

# ---- Docker / containers ----
.docker/
docker-data/
*.tar

# ---- Databases / local data ----
*.sqlite3
*.db
*.db-journal
postgres-data/
minio-data/

# ---- Terraform / Infra (if added) ----
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ---- Test artifacts ----
test-results/
playwright-report/
allure-results/

# ---- Archives ----
*.zip
*.tar.gz
*.rar
*.7z
